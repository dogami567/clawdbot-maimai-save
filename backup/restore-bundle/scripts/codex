#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: scripts/codex <prompt> [--cwd <path>] [--model <model>]" >&2
  exit 1
fi

cwd=""
model=""
args=()
while [ "$#" -gt 0 ]; do
  case "$1" in
    --cwd)
      cwd="${2:-}"
      shift 2
      ;;
    --model)
      model="${2:-}"
      shift 2
      ;;
    --)
      shift
      args+=("$@")
      break
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

prompt="${args[*]}"

export CODEX_BRIDGE_PROMPT="${prompt}"
if [ -n "$cwd" ]; then
  export CODEX_BRIDGE_CWD="$cwd"
fi
if [ -n "$model" ]; then
  export CODEX_BRIDGE_MODEL="$model"
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
node "${script_dir}/codex-bridge-run.mjs"

